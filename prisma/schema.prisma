generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String
  password   String
  role       Role     @default(STUDENT)
  avatar     String?
  bio        String?
  phone      String?
  isVerified Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  taughtCourses      Course[]            @relation("TutorCourses")
  enrollments        Enrollment[]
  notifications      Notification[]
  payments           Payment[]
  reviews            Review[]
  sessions           Session[]
  assessmentAttempts AssessmentAttempt[] // For student attempts

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  createdAt   DateTime @default(now())
  courses     Course[]

  @@map("categories")
}

model Course {
  id           String       @id @default(cuid())
  title        String
  slug         String       @unique
  description  String       @db.LongText
  thumbnail    String?
  price        Float        @default(0)
  currency     String       @default("NGN")
  status       CourseStatus @default(PENDING)
  level        String       @default("Beginner")
  duration     String?
  language     String       @default("English")
  requirements Json
  objectives   Json
  tags         Json
  isFreemium   Boolean      @default(false)
  tutorId      String
  categoryId   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  category     Category?    @relation(fields: [categoryId], references: [id])
  tutor        User         @relation("TutorCourses", fields: [tutorId], references: [id])
  enrollments  Enrollment[]
  modules      Module[]
  payments     Payment[]
  reviews      Review[]
  assessments  Assessment[]

  @@index([categoryId])
  @@index([tutorId])
  @@map("courses")
}

model Module {
  id          String       @id @default(cuid())
  title       String
  description String?
  order       Int
  courseId    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  materials   Material[]
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  assessments Assessment[]

  @@index([courseId])
  @@map("modules")
}

model Material {
  id          String       @id @default(cuid())
  title       String
  description String?
  type        MaterialType
  fileUrl     String?
  videoUrl    String?
  content     String?      @db.LongText
  duration    Int?
  fileSize    Int?
  mimeType    String?
  order       Int
  isFree      Boolean      @default(false)
  moduleId    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  module      Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress    Progress[]

  @@index([moduleId])
  @@map("materials")
}

model Enrollment {
  id          String           @id @default(cuid())
  userId      String
  courseId    String
  status      EnrollmentStatus @default(ACTIVE)
  progress    Float            @default(0)
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  course      Course           @relation(fields: [courseId], references: [id])
  user        User             @relation(fields: [userId], references: [id])
  progresses  Progress[]

  @@unique([userId, courseId])
  @@index([courseId])
  @@map("enrollments")
}

model Progress {
  id           String     @id @default(cuid())
  enrollmentId String
  materialId   String
  completed    Boolean    @default(false)
  watchTime    Int?
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  material     Material   @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, materialId])
  @@index([materialId])
  @@map("progress")
}

model Payment {
  id          String        @id @default(cuid())
  userId      String
  courseId    String
  amount      Float
  currency    String        @default("NGN")
  status      PaymentStatus @default(PENDING)
  provider    String
  providerRef String?       @unique
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  course      Course        @relation(fields: [courseId], references: [id])
  user        User          @relation(fields: [userId], references: [id])

  @@index([courseId])
  @@index([userId])
  @@map("payments")
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
  @@index([courseId])
  @@map("reviews")
}

model Announcement {
  id         String   @id @default(cuid())
  title      String
  content    String
  targetRole Role?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@map("announcements")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String   @db.Text
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId])
  @@map("notifications")
}

enum Role {
  STUDENT
  TUTOR
  ADMIN
}

enum CourseStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum MaterialType {
  PDF
  IMAGE
  TEXT
  VIDEO
  VIDEO_LINK
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  SUSPENDED
}

enum AssessmentType {
  TEST
  EXAM
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  ESSAY
}

model Assessment {
  id               String         @id @default(cuid())
  title            String
  description      String?
  type             AssessmentType
  courseId         String
  moduleId         String?
  timeLimit        Int?
  passingScore     Int?
  maxAttempts      Int?           @default(1)
  shuffleQuestions Boolean        @default(false)
  showResults      Boolean        @default(true)
  isPublished      Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // Relations
  course    Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module    Module?             @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  questions Question[]
  attempts  AssessmentAttempt[]

  @@index([courseId])
  @@index([moduleId])
  @@map("assessments")
}

model Question {
  id            String       @id @default(cuid())
  assessmentId  String
  text          String
  type          QuestionType
  points        Int          @default(1)
  options       Json?
  correctAnswer Json?
  explanation   String?
  order         Int
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Relations
  assessment Assessment      @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  answers    StudentAnswer[]

  @@index([assessmentId])
  @@map("questions")
}

model AssessmentAttempt {
  id           String    @id @default(cuid())
  assessmentId String
  studentId    String
  startedAt    DateTime  @default(now())
  submittedAt  DateTime?
  score        Float?
  passed       Boolean?  @default(false)
  timeSpent    Int?
  answers      Json?
  status       String    @default("in_progress")

  // Relations
  assessment      Assessment      @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  student         User            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  questionAnswers StudentAnswer[]

  @@unique([assessmentId, studentId, status])
  @@index([assessmentId])
  @@index([studentId])
  @@map("assessment_attempts")
}

model StudentAnswer {
  id           String    @id @default(cuid())
  attemptId    String
  questionId   String
  answer       Json
  isCorrect    Boolean?  @default(false)
  pointsEarned Int?      @default(0)
  feedback     String?
  gradedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  attempt  AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question          @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
  @@map("student_answers")
}
